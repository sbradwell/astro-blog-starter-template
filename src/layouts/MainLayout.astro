---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<!-- Google tag (gtag.js) -->
		<script is:inline src="/scripts/gtag-init.js"></script>
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-6NW2DV29T6"></script>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

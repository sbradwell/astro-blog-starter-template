---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

export const prerender = false;

const capabilities = [
	{
		title: 'AI Strategy & Operating Model',
		description:
			'Define where AI creates real value and what must be in place before deploying it.',
		detail:
			'A clear operating model and roadmap aligned to real execution constraints. Designed to be delivered iteratively to ensure the fastest path to value.',
	},
	{
		title: 'AI Control Plane & Platform Foundation',
		description:
			'Implement a governed AI control plane aligned to your identity, data, and policy environment.',
		detail:
			'A governed AI control plane integrated with Microsoft 365 and Azure, enabling secure, policy-aligned agent deployment across Teams, Word, Excel, and your core systems.',
	},
	{
		title: 'Applied Agentic Process Automation',
		description:
			'Deploy purpose-built agents across underwriting, claims, reporting, and operations.',
		detail:
			'Offload repetitive tasks and scale throughput with the same staffing levels, delivering measurable impact to expense ratio, underwriting capacity, and combined ratio.',
	},
];

const reasons = [
	'Built for regulated insurance environments where control is non-negotiable.',
	'Designed for Microsoft-first organizations that will not move AI outside their governance model.',
	'Deep expertise across P&C, Farm, A&H, and stop-loss.',
	'Bridges business, IT, and compliance to move beyond fragmented AI efforts.',
	'Enables your team to adopt, operate, and scale AI, not depend on vendors.',
];
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero section">
		<div class="hero-copy">
			<p class="eyebrow">NorthLine Consulting</p>
			<h1>Move beyond AI pilots. Make AI real—under governance.</h1>
			<p class="lead">
				NorthLine helps insurers realize the value of Agentic AI Process Automation for
				regulated environments, all within your own Microsoft and Azure tenant, in partnership
				with your IT and compliance teams.
			</p>
			<div class="hero-actions">
				<button class="button button-primary" type="button" data-open-contact>
					Start a Conversation
				</button>
				<a class="button button-secondary" href="#current-reality">See Current Reality</a>
			</div>
		</div>

		<div class="hero-panel">
			<div class="northline-mark" aria-hidden="true">
				<span class="northline-ring northline-ring-outer"></span>
				<span class="northline-ring northline-ring-inner"></span>
				<span class="northline-axis northline-axis-vertical"></span>
				<span class="northline-axis northline-axis-horizontal"></span>
				<span class="northline-axis northline-axis-angle"></span>
				<span class="northline-point"></span>
			</div>
		</div>
	</section>

	<section id="current-reality" class="section adoption-section">
		<div class="section-heading">
			<p class="eyebrow">Current Reality</p>
			<h2>AI adoption is already happening. It&apos;s just not controlled.</h2>
		</div>

		<div class="adoption-grid">
			<div class="platform-approach-card adoption-card">
				<div class="adoption-list">
					<div class="adoption-list-item">
						<span class="reason-line" aria-hidden="true"></span>
						<p>Business teams are using unapproved AI tools to keep up with workload.</p>
					</div>
					<div class="adoption-list-item">
						<span class="reason-line" aria-hidden="true"></span>
						<p>IT and cyber teams are blocking AI to protect data and compliance.</p>
					</div>
					<div class="adoption-list-item">
						<span class="reason-line" aria-hidden="true"></span>
						<p>Copilot pilots are ending without a clear path forward.</p>
					</div>
					<div class="adoption-list-item">
						<span class="reason-line" aria-hidden="true"></span>
						<p>Manual processes are still breaking under volume and complexity.</p>
					</div>
				</div>
				<p class="adoption-line">This creates fragmentation, risk, and missed opportunity.</p>
			</div>

			<div class="platform-cta adoption-subsection">
				<div class="section-heading adoption-heading">
					<p class="eyebrow">Where Initiatives Stall</p>
					<h3>Most AI initiatives stall here</h3>
				</div>
				<div class="stall-grid">
					<div class="stall-item">
						<h4>No defined operating model</h4>
					</div>
					<div class="stall-item">
						<h4>No control over model usage or data</h4>
					</div>
					<div class="stall-item">
						<h4>Disconnected tools and duplicated workflows</h4>
					</div>
					<div class="stall-item">
						<h4>No auditability in regulated environments</h4>
					</div>
				</div>
				<div class="adoption-cta-group">
					<p class="adoption-line adoption-line-strong">
						NorthLine provides a governed path forward.
					</p>
					<a class="button button-secondary" href="#practice">Review our 3 Phase Practice</a>
				</div>
			</div>
		</div>
	</section>

	<section id="practice" class="section practice-section">
		<div class="section-heading">
			<p class="eyebrow">Practice</p>
			<h2>Governed AI adoption for insurance</h2>
		</div>

		<div class="capability-grid">
			{capabilities.map((item) => (
				<article class="card">
					<h3>{item.title}</h3>
					<div class="card-body">
						<p>{item.description}</p>
					</div>
					<div class="card-outcome">
						<p class="card-outcome-label">Outcome</p>
						<p>{item.detail}</p>
					</div>
				</article>
			))}
		</div>

		<div class="section-cta">
			<a class="button button-secondary" href="#ai-platform">Review our Approach</a>
		</div>
	</section>

	<section id="ai-platform" class="section ai-platform-section">
		<div class="section-heading">
			<p class="eyebrow">AI Platform Approach</p>
			<h2>Control before automation</h2>
			<p class="lead">
				NorthLine assesses your environment, aligns controls to your use cases, and implements a
				governed AI platform and purpose built, human augmenting, agentic workflows within your
				Microsoft tenant.
			</p>
			<p class="hero-detail">
				This enables purpose-built agents to be deployed safely under your policies, data
				boundaries, and governance model.
			</p>
		</div>

		<div class="platform-approach-card">
			<div class="platform-points">
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Secure access enforced through identity and API control.</p>
				</div>
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Governed model usage within an AI control plane.</p>
				</div>
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Separation of systems of record, documents, and AI execution layers.</p>
				</div>
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Event-driven integration without duplicating systems.</p>
				</div>
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Full observability, auditability, and cost visibility.</p>
				</div>
			</div>

			<div class="platform-cta">
				<p>
					We align your controls, data, and use cases so AI can be deployed safely inside your
					environment, not outside of it.
				</p>
				<a class="button button-secondary" href="/architecture">Explore the Platform Blueprint</a>
			</div>
		</div>
	</section>

	<section id="why" class="section why-section">
		<div class="section-heading">
			<p class="eyebrow">Why NorthLine</p>
			<h2>Built for complexity. Designed for control.</h2>
		</div>

		<div class="reason-list">
			{reasons.map((reason) => (
				<div class="reason-item">
					<span class="reason-line" aria-hidden="true"></span>
					<p>{reason}</p>
				</div>
			))}
		</div>
	</section>

	<section id="contact" class="section contact-section">
		<div class="contact-card">
			<div>
				<p class="eyebrow">Contact</p>
				<h2>Bring the operating challenge into focus</h2>
			</div>
			<div class="contact-content">
				<p>
					NorthLine works with insurance leadership teams defining AI strategy, architecture,
					governance, and controlled process automation in complex regulated environments.
				</p>
				<button class="button button-primary" type="button" data-open-contact>
					Start a Conversation
				</button>
			</div>
		</div>
	</section>

	<dialog class="contact-modal" id="contact-modal">
		<form class="contact-modal-card" id="contact-form" method="dialog" novalidate>
			<div class="contact-modal-header">
				<div>
					<p class="eyebrow">Contact</p>
					<h2>Start a Conversation</h2>
				</div>
				<button class="contact-modal-close" type="button" aria-label="Close form" data-close-contact>
					<span aria-hidden="true">&times;</span>
				</button>
			</div>

			<div class="contact-form-grid">
				<label class="field">
					<span>Name</span>
					<input id="contact-name" name="name" type="text" autocomplete="name" required />
				</label>

				<label class="field">
					<span>Email</span>
					<input id="contact-email" name="email" type="email" autocomplete="email" required />
				</label>

				<label class="field">
					<span>Company</span>
					<input id="contact-company" name="company" type="text" autocomplete="organization" required />
				</label>

				<label class="field field-full">
					<span>Message</span>
					<textarea
						id="contact-message"
						name="message"
						rows="5"
						required
						placeholder="Briefly describe the problem, line, or initiative."
					></textarea>
				</label>
			</div>

			<p class="form-status" id="contact-status" aria-live="polite"></p>

			<div class="contact-modal-actions">
				<button class="button button-secondary" type="button" data-close-contact>Cancel</button>
				<button class="button button-primary" type="submit" id="contact-submit">
					Send Inquiry
				</button>
			</div>
		</form>
	</dialog>
</MainLayout>

<script type="module" src="/scripts/contact-form.js"></script>

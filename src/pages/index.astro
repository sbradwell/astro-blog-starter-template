---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_DESCRIPTION, WORKFLOW_SAVINGS } from '../consts';

export const prerender = false;

const capabilities = [
	{
		title: 'AI Use Case & Operating Model',
		description:
			'Identify the workflows where AI can create real value, define what governance and controls are required, and align business, IT, and compliance before deployment begins.',
		detail:
			'A clear roadmap for governed AI deployment tied to real operating pain points and practical execution constraints.',
	},
	{
		title: 'Microsoft-Aligned AI Foundation',
		description:
			'Configure the controls, identity model, access patterns, and integration approach required to deploy AI safely inside your Microsoft environment.',
		detail:
			'A secure foundation for governed AI deployment across Microsoft 365, Azure, Teams, documents, and core insurance workflows.',
	},
	{
		title: 'Purpose-Built Insurance Agents',
		description:
			'Deploy purpose-built AI agents for underwriting, claims, reporting, and operations—focused on the workflows where manual effort, delays, and duplication create the most drag.',
		detail:
			'Reduced manual workload, better throughput, and measurable business impact without adding another disconnected system.',
	},
];

const reasons = [
	'We work where underwriting, operations, and data don’t line up cleanly—and never fully will.',
	'We design around existing systems, not ideal ones—because replacement is rarely the first step.',
	'We understand the weight of governance, compliance, and cyber—and how to move forward without breaking them.',
	'We’ve worked inside organizations where business, IT, and risk don’t naturally align—and know how to bring them together.',
	'We balance speed and control, so progress happens without creating downstream risk or rework.',
	'We build for teams that are already busy—solutions have to fit into real workflows, not add to them.',
];

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: 'NorthLine Consulting',
		url: 'https://northline.consulting',
		logo: 'https://northline.consulting/logo-icon.svg',
		image: 'https://northline.consulting/og-image.png',
		description:
			'NorthLine Consulting helps specialty insurers deploy governed AI agents inside their Microsoft environment to automate real insurance workflows securely.',
		founder: {
			'@type': 'Person',
			name: 'Steve Bradwell',
		},
		email: 'steve.bradwell@northline.consulting',
		areaServed: {
			'@type': 'Place',
			name: 'North America',
		},
		knowsAbout: [
			'Insurance AI consulting',
			'Specialty insurance',
			'Governed AI deployment',
			'Microsoft-aligned AI architecture',
			'Insurance workflow automation',
			'MGU operating models',
			'Claims document processing',
			'Bordereaux processing',
			'Statutory reporting',
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'Insurance AI Consulting',
		provider: {
			'@type': 'Organization',
			name: 'NorthLine Consulting',
			url: 'https://northline.consulting',
		},
		serviceType: 'Insurance AI consulting',
		areaServed: {
			'@type': 'Place',
			name: 'North America',
		},
		audience: {
			'@type': 'Audience',
			audienceType: 'Specialty insurers, MGUs, and regulated insurance organizations',
		},
		description:
			'Governed AI consulting for specialty insurers, focused on deploying AI agents inside Microsoft environments with governance, control, and workflow integration.',
	},
];
---

<MainLayout
	title="AI Consulting for Specialty Insurance | NorthLine"
	description={SITE_DESCRIPTION}
	structuredData={structuredData}
>
	<section class="hero section">
		<div class="hero-copy">
			<p class="eyebrow">NorthLine</p>
			<h1>We build AI agents for specialty insurance workflows</h1>
			<p class="lead">
				NorthLine delivers AI agents for specialty insurers&mdash;deployed inside your Microsoft
				environment and integrated with your existing systems, policies, and controls to
				automate underwriting, claims, and operations.
			</p>
			<div class="hero-actions">
				<button class="button button-primary" type="button" data-open-contact>
					Start with one agent
				</button>
				<a class="button button-secondary" href="#current-reality">See Current Reality</a>
			</div>
		</div>

		<div class="hero-panel">
			<div class="northline-mark" aria-hidden="true">
				<span class="northline-ring northline-ring-outer"></span>
				<span class="northline-ring northline-ring-inner"></span>
				<span class="northline-axis northline-axis-vertical"></span>
				<span class="northline-axis northline-axis-horizontal"></span>
				<span class="northline-axis northline-axis-angle"></span>
				<span class="northline-point"></span>
			</div>
		</div>
	</section>

	<section id="current-reality" class="section adoption-section">
		<div class="section-heading">
			<p class="eyebrow">Current Reality</p>
			<h2>AI adoption is already happening. It&apos;s just not governed.</h2>
		</div>

		<div class="adoption-grid">
			<div class="platform-approach-card adoption-card">
				<div class="adoption-list">
					<p>
						<strong>
							Specialty insurance teams are turning to AI out of necessity, not
							experimentation.
						</strong>
					</p>
					<p>
						Limited vendor support, document-heavy manual workflows, and complex products
						leave underwriting, claims, and operations teams without scalable systems.
					</p>
					<p>
						This creates an opportunity for specialty insurers to leapfrog legacy tooling by
						moving directly to governed, agent-based execution rather than waiting for
						platforms that may never arrive.
					</p>
				</div>
				<p class="adoption-line">
					NorthLine provides a governed path to deploy AI inside your environment, not around
					it.
				</p>
			</div>

			<div class="platform-cta adoption-subsection">
				<div class="section-heading adoption-heading">
					<p class="eyebrow">Where Initiatives Stall</p>
					<h3>Most AI initiatives stall here</h3>
				</div>
				<div class="stall-grid">
					<div class="stall-item">
						<h4>No defined operating model for AI</h4>
					</div>
					<div class="stall-item">
						<h4>No control over data, model usage, or access</h4>
					</div>
					<div class="stall-item">
						<h4>Disconnected tools and duplicated workflows</h4>
					</div>
					<div class="stall-item">
						<h4>No auditability in regulated environments</h4>
					</div>
				</div>
				<div class="adoption-cta-group">
					<p class="adoption-line adoption-line-strong">
						NorthLine provides a governed path to deploy AI inside your environment, not
						around it.
					</p>
					<a class="button button-secondary" href="#practice">See How It Works</a>
				</div>
			</div>
		</div>
	</section>

	<section id="practice" class="section practice-section">
		<div class="section-heading">
			<p class="eyebrow">How it Works</p>
			<h2>From workflow to production AI agents</h2>
		</div>

		<div class="capability-grid">
			{capabilities.map((item) => (
				<article class="card">
					<h3>{item.title}</h3>
					<div class="card-body">
						<p>{item.description}</p>
					</div>
					<div class="card-outcome">
						<p class="card-outcome-label">Outcome</p>
						<p>{item.detail}</p>
					</div>
				</article>
			))}
		</div>

		<div class="section-cta">
			<a class="button button-secondary" href="#agents">
				See Where Agents Fit
			</a>
		</div>
	</section>

	<section id="agents" class="section common-workflows-section">
		<div class="section-heading">
			<p class="eyebrow">Agents</p>
			<h2>Where AI agents deliver immediate operational impact</h2>
			<p class="lead">
				NorthLine focuses on governed AI agents that support document-heavy, operationally
				repetitive insurance workflows. They are deployed around the systems, controls, and
				teams already in place.
			</p>
		</div>

		<div class="workflow-savings-grid">
			{WORKFLOW_SAVINGS.map((item) => (
				<article class="workflow-savings-card">
					<h3>{item.title}</h3>
					<p>{item.description}</p>
				</article>
			))}
		</div>

		<div class="section-cta">
			<a class="button button-secondary" href="/specialty-insurance-ai-agents">
				Explore Agent Examples
			</a>
		</div>
	</section>

	<section id="platform" class="section ai-platform-section">
		<div class="section-heading">
			<p class="eyebrow">Platform</p>
			<h2>The platform layer for governed AI agents in insurance</h2>
			<p class="lead">
				NorthLine builds a governed AI platform aligned to Microsoft 365 and agent-oriented
				capabilities, deployed inside your environment. That means agents operate with your
				existing identity, security, data, and policy controls rather than through another
				disconnected external layer.
			</p>
		</div>

		<div class="platform-approach-card">
			<div class="platform-points">
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Secure access aligned to your identity and permissions model</p>
				</div>
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Governed model usage with policy and approval controls</p>
				</div>
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Integration with documents, systems, and workflows already in use</p>
				</div>
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Event-driven architecture without duplicating systems of record</p>
				</div>
				<div class="platform-point">
					<span class="reason-line" aria-hidden="true"></span>
					<p>Auditability, observability, and cost visibility from day one</p>
				</div>
			</div>

			<div class="platform-cta">
				<p>
					The result is a platform foundation for AI agents that supports business outcomes while
					staying aligned with IT, cyber, and compliance.
				</p>
				<a class="button button-secondary" href="/insurance-ai-deployment">
					Explore the Platform
				</a>
			</div>
		</div>
	</section>

	<section id="why" class="section why-section">
		<div class="section-heading">
			<p class="eyebrow">Why NorthLine</p>
			<h2>Built inside the reality of specialty insurance. Designed to move within it.</h2>
		</div>

		<div class="reason-list">
			{reasons.map((reason) => (
				<div class="reason-item">
					<span class="reason-line" aria-hidden="true"></span>
					<p>{reason}</p>
				</div>
			))}
		</div>
	</section>

	<section id="contact" class="section contact-section">
		<div class="contact-card">
			<div>
				<p class="eyebrow">Contact</p>
				<h2>Bring one workflow into focus</h2>
			</div>
			<div class="contact-content">
				<p>
					NorthLine works with insurance leadership teams to identify high-value AI use cases,
					design the right governance approach, and deploy controlled automation inside complex
					regulated environments.
				</p>
				<button class="button button-primary" type="button" data-open-contact>
					Start with one agent
				</button>
			</div>
		</div>
	</section>

	<dialog class="contact-modal" id="contact-modal">
		<form class="contact-modal-card" id="contact-form" method="dialog" novalidate>
			<div class="contact-modal-header">
				<div>
					<p class="eyebrow">Contact</p>
					<h2>Start with one agent</h2>
				</div>
				<button class="contact-modal-close" type="button" aria-label="Close form" data-close-contact>
					<span aria-hidden="true">&times;</span>
				</button>
			</div>

			<div class="contact-form-grid">
				<label class="field">
					<span>Name</span>
					<input id="contact-name" name="name" type="text" autocomplete="name" required />
				</label>

				<label class="field">
					<span>Email</span>
					<input id="contact-email" name="email" type="email" autocomplete="email" required />
				</label>

				<label class="field">
					<span>Company</span>
					<input id="contact-company" name="company" type="text" autocomplete="organization" required />
				</label>

				<label class="field field-full">
					<span>Message</span>
					<textarea
						id="contact-message"
						name="message"
						rows="5"
						required
						placeholder="Briefly describe the problem, line, or initiative."
					></textarea>
				</label>
			</div>

			<p class="form-status" id="contact-status" aria-live="polite"></p>

			<div class="contact-modal-actions">
				<button class="button button-secondary" type="button" data-close-contact>Cancel</button>
				<button class="button button-primary" type="submit" id="contact-submit">
					Send Inquiry
				</button>
			</div>
		</form>
	</dialog>
</MainLayout>

<script type="module" src="/scripts/contact-form.js"></script>

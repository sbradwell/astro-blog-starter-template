---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const capabilities = [
	{
		title: 'Technology strategy',
		description:
			'Platform direction, vendor selection, and roadmap sequencing for carriers and MGUs operating across legacy systems, fragmented workflows, and limited capacity to scale.',
		detail:
			'Defines a clear operating model and technology path, aligning platform decisions to reduce fragmentation and support scalable growth.',
	},
	{
		title: 'Modernization',
		description:
			'Redesign of underwriting intake, bordereaux processing, policy administration, claims, and reporting where manual handoffs and reconciliation still drive cost and delay.',
		detail:
			'Eliminates redundant workflows, reduces rekeying across systems, and creates more consistent, scalable execution.',
	},
	{
		title: 'Applied AI',
		description:
			'Practical application of AI across document intake, triage, exception handling, and operational review where value is clear today.',
		detail:
			'Moves beyond stalled Copilot adoption and fragmented tooling, identifying where AI can reduce manual processing, improve decision speed, and fit existing operations.',
	},
];

const reasons = [
	'Commercial off-the-shelf options are limited in specialty lines.',
	'Legacy internal systems and manual workarounds do not scale.',
	'Property & Casualty platforms rarely fit the product or workflow.',
	'Experience in underserved and complex lines including Employer Stop Loss, Farm, and Agribusiness.',
];
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero section">
		<div class="hero-copy">
			<p class="eyebrow">NorthLine Consulting</p>
			<h1>Strategy &amp; Technology for Specialty Insurance</h1>
			<p class="lead">
				NorthLine advises insurers and MGUs facing complex products, legacy workflows, and
				pressure to modernize with clarity and control.
			</p>
			<p class="hero-detail">
				Focus areas include Accident &amp; Health, including Employer Stop Loss, and other specialty
				lines where operations remain hard to standardize.
			</p>
			<div class="hero-actions">
				<button class="button button-primary" type="button" data-open-contact>
					Start a Conversation
				</button>
				<a class="button button-secondary" href="#practice">View Practice</a>
			</div>
		</div>

		<div class="hero-panel">
			<div class="northline-mark" aria-hidden="true">
				<span class="northline-ring northline-ring-outer"></span>
				<span class="northline-ring northline-ring-inner"></span>
				<span class="northline-axis northline-axis-vertical"></span>
				<span class="northline-axis northline-axis-horizontal"></span>
				<span class="northline-axis northline-axis-angle"></span>
				<span class="northline-point"></span>
			</div>
		</div>
	</section>

	<section id="practice" class="section practice-section">
		<div class="section-heading">
			<p class="eyebrow">Practice</p>
			<h2>Scalable operating models for specialty insurance</h2>
		</div>

		<div class="capability-grid">
			{capabilities.map((item) => (
				<article class="card">
					<h3>{item.title}</h3>
					<div class="card-body">
						<p>{item.description}</p>
					</div>
					<div class="card-outcome">
						<p class="card-outcome-label">Outcome</p>
						<p>{item.detail}</p>
					</div>
				</article>
			))}
		</div>
	</section>

	<section id="why" class="section">
		<div class="section-heading">
			<p class="eyebrow">Why NorthLine</p>
			<h2>Specific guidance for specialty carriers and MGUs</h2>
		</div>

		<div class="reason-list">
			{reasons.map((reason) => (
				<div class="reason-item">
					<span class="reason-line" aria-hidden="true"></span>
					<p>{reason}</p>
				</div>
			))}
		</div>
	</section>

	<section id="contact" class="section contact-section">
		<div class="contact-card">
			<div>
				<p class="eyebrow">Contact</p>
				<h2>Bring the operating problem into focus</h2>
			</div>
			<div class="contact-content">
				<p>
					NorthLine works with leadership teams facing legacy constraints, scaling pressure, and
					the need for more modern operating infrastructure.
				</p>
				<button class="button button-primary" type="button" data-open-contact>
					Start a Conversation
				</button>
			</div>
		</div>
	</section>

	<dialog class="contact-modal" id="contact-modal">
		<form class="contact-modal-card" id="contact-form" method="dialog" novalidate>
			<div class="contact-modal-header">
				<div>
					<p class="eyebrow">Contact</p>
					<h2>Start a Conversation</h2>
				</div>
				<button class="contact-modal-close" type="button" aria-label="Close form" data-close-contact>
					<span aria-hidden="true">&times;</span>
				</button>
			</div>

			<div class="contact-form-grid">
				<label class="field">
					<span>Name</span>
					<input id="contact-name" name="name" type="text" autocomplete="name" required />
				</label>

				<label class="field">
					<span>Email</span>
					<input id="contact-email" name="email" type="email" autocomplete="email" required />
				</label>

				<label class="field">
					<span>Company</span>
					<input id="contact-company" name="company" type="text" autocomplete="organization" required />
				</label>

				<label class="field field-full">
					<span>Message</span>
					<textarea
						id="contact-message"
						name="message"
						rows="5"
						required
						placeholder="Briefly describe the problem, line, or initiative."
					></textarea>
				</label>
			</div>

			<p class="form-status" id="contact-status" aria-live="polite"></p>

			<div class="contact-modal-actions">
				<button class="button button-secondary" type="button" data-close-contact>Cancel</button>
				<button class="button button-primary" type="submit" id="contact-submit">
					Send Inquiry
				</button>
			</div>
		</form>
	</dialog>
</MainLayout>

<script type="module" src="/scripts/contact-form.js"></script>

---
import MainLayout from '../layouts/MainLayout.astro';
import { COMMON_WORKFLOWS } from '../consts';

const pageTitle = 'AI Use Cases for Insurance Workflows | NorthLine';
const pageDescription =
	'Common specialty insurance workflows where governed AI can reduce manual workload, improve throughput, and support controlled execution.';
---

<MainLayout title={pageTitle} description={pageDescription}>
	<section class="section architecture-page-intro">
		<div class="section-heading">
			<p class="eyebrow">Common Workflows</p>
			<h1>Where governed AI creates immediate operational leverage</h1>
			<p class="lead">
				Specialty insurers do not need a generic AI platform story. They need governed execution
				in the workflows where document volume, operational complexity, and staffing constraints
				create the most friction.
			</p>
		</div>

		<div class="workflow-grid">
			{COMMON_WORKFLOWS.map((workflow) => (
				<article class="workflow-card">
					<h3>{workflow.title}</h3>
					<p>{workflow.problem}</p>
					<div class="workflow-opportunity">
						<p class="workflow-opportunity-label">Where AI Helps</p>
						<p>{workflow.opportunity}</p>
					</div>
				</article>
			))}
		</div>
	</section>

	<section class="section contact-section architecture-contact-section">
		<div class="contact-card">
			<div>
				<p class="eyebrow">Next Step</p>
				<h2>See how these workflows are deployed safely</h2>
			</div>
			<div class="contact-content">
				<p>
					NorthLine helps specialty insurers move from workflow opportunity to governed
					deployment inside Microsoft-aligned environments.
				</p>
				<a class="button button-secondary" href="/insurance-ai-deployment">
					Explore the Deployment Blueprint
				</a>
			</div>
		</div>
	</section>
</MainLayout>

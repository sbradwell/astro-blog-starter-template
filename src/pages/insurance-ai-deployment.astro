---
import MainLayout from '../layouts/MainLayout.astro';
import ArchitectureDiagram from '../components/ArchitectureDiagram.astro';

const pageTitle = 'Insurance AI Deployment for Specialty Insurers | NorthLine Consulting';
const pageDescription =
	'How specialty insurers deploy governed AI agents inside Microsoft environments, with architecture, controls, and workflow integration.';
---

<MainLayout title={pageTitle} description={pageDescription}>
	<section class="section architecture-page-intro">
		<div class="section-heading">
			<p class="eyebrow">Reference Architecture</p>
			<h1>Governed AI deployment for specialty insurance</h1>
		</div>

		<p class="architecture-page-copy">
			AI can reduce manual workload across underwriting, claims, and operations, but regulated
			insurers need a secure and governed way to deploy it.
		</p>

		<p class="architecture-page-copy architecture-page-copy-emphasis">
			NorthLine provides the architecture and controls to deploy AI agents inside your Microsoft
			environment, aligned with IT, compliance, and human oversight.
		</p>

		<p class="architecture-page-copy">
			This reference blueprint shows how governed AI can be integrated into real insurance
			workflows without adding another disconnected external layer.
		</p>

		<ArchitectureDiagram />

		<p class="architecture-page-copy architecture-page-copy-emphasis">
			The blueprint is not the goal. The goal is deploying useful AI agents safely, with human
			oversight, auditability, and integration into real insurance workflows.
		</p>

		<p class="architecture-page-copy">
			Designed so AI handles repetitive work while underwriting, claims, and operational
			decisions remain under human authority.
		</p>
	</section>

	<section class="section contact-section architecture-contact-section">
		<p class="eyebrow">You&apos;ve moved beyond pilots. Now make it real.</p>
		<div class="contact-card">
			<div>
				<p class="eyebrow">Start With One Workflow</p>
				<h2>Start with one governed AI workflow</h2>
			</div>
			<div class="contact-content">
				<p>
					NorthLine works with business, IT, and compliance teams to identify the right use
					case, define the architecture, and deploy AI safely inside regulated insurance
					environments.
				</p>
				<button class="button button-primary" type="button" data-open-contact>
					Start a Conversation
				</button>
			</div>
		</div>
	</section>

	<dialog class="contact-modal" id="contact-modal">
		<form class="contact-modal-card" id="contact-form" method="dialog" novalidate>
			<div class="contact-modal-header">
				<div>
					<p class="eyebrow">Contact</p>
					<h2>Start a Conversation</h2>
				</div>
				<button class="contact-modal-close" type="button" aria-label="Close form" data-close-contact>
					<span aria-hidden="true">&times;</span>
				</button>
			</div>

			<div class="contact-form-grid">
				<label class="field">
					<span>Name</span>
					<input id="contact-name" name="name" type="text" autocomplete="name" required />
				</label>

				<label class="field">
					<span>Email</span>
					<input id="contact-email" name="email" type="email" autocomplete="email" required />
				</label>

				<label class="field">
					<span>Company</span>
					<input id="contact-company" name="company" type="text" autocomplete="organization" required />
				</label>

				<label class="field field-full">
					<span>Message</span>
					<textarea
						id="contact-message"
						name="message"
						rows="5"
						required
						placeholder="Briefly describe the problem, line, or initiative."
					></textarea>
				</label>
			</div>

			<p class="form-status" id="contact-status" aria-live="polite"></p>

			<div class="contact-modal-actions">
				<button class="button button-secondary" type="button" data-close-contact>Cancel</button>
				<button class="button button-primary" type="submit" id="contact-submit">
					Send Inquiry
				</button>
			</div>
		</form>
	</dialog>
</MainLayout>

<script type="module" src="/scripts/contact-form.js"></script>

---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-shell">
		<p class="footer-brand">NorthLine Consulting</p>
		<p class="footer-copy">Governed AI deployment for specialty insurance</p>
		<p class="footer-copy">&copy; {today.getFullYear()} NorthLine Consulting</p>
	</div>
</footer>

<style>
	.site-footer {
		padding: 0 1.25rem 2.5rem;
	}

	.footer-shell {
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 2rem;
		border-top: 1px solid var(--surface-line);
		display: grid;
		gap: 0.35rem;
	}

	.footer-brand,
	.footer-copy {
		margin: 0;
	}

	.footer-brand {
		color: var(--text-strong);
		font-size: 0.88rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.footer-copy {
		color: var(--text-muted);
		font-size: 0.94rem;
	}
</style>

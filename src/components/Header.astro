---
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
	<nav class="nav-shell">
		<a class="brand" href="/">
			<span class="brand-mark" aria-hidden="true"></span>
			<span>{SITE_TITLE}</span>
		</a>

		<div class="nav-links">
			<a href="#practice">Practice</a>
			<a href="#why">Why NorthLine</a>
			<a href="#contact">Contact</a>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 0.85rem 1.25rem 0;
	}

	.nav-shell {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0.72rem 0.95rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
		border: 1px solid var(--surface-line);
		border-radius: 999px;
		background: rgba(7, 13, 22, 0.76);
		backdrop-filter: blur(16px);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		color: var(--text-strong);
		font-size: 0.84rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.brand-mark {
		width: 0.95rem;
		height: 0.95rem;
		border-radius: 999px;
		border: 1px solid rgba(124, 216, 242, 0.8);
		background:
			linear-gradient(135deg, transparent 46%, rgba(124, 216, 242, 0.95) 50%, transparent 54%),
			radial-gradient(circle at center, rgba(124, 216, 242, 0.18), transparent 70%);
		box-shadow: 0 0 0 0.25rem rgba(124, 216, 242, 0.08);
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.nav-links a {
		color: var(--text-muted);
		font-size: 0.88rem;
		text-decoration: none;
		transition: color 160ms ease;
	}

	.nav-links a:hover {
		color: var(--text-strong);
	}

	@media (max-width: 720px) {
		.site-header {
			padding: 0.7rem 1rem 0;
		}

		.nav-shell {
			flex-direction: column;
			align-items: flex-start;
			border-radius: 1.5rem;
		}

		.nav-links {
			gap: 0.85rem 1rem;
		}
	}
</style>

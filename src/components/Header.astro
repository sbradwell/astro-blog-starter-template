---
import { SITE_TITLE } from '../consts';

const isArchitecturePage = Astro.url.pathname === '/architecture' || Astro.url.pathname === '/architecture/';
const currentRealityHref = isArchitecturePage ? '/#current-reality' : '#current-reality';
const practiceHref = isArchitecturePage ? '/#practice' : '#practice';
const aiPlatformHref = isArchitecturePage ? '/#ai-platform' : '#ai-platform';
const blueprintHref = '/architecture';
const whyHref = isArchitecturePage ? '/#why' : '#why';
const getStartedHref = isArchitecturePage ? '/#contact' : '#contact';
---

<header class="site-header">
	<nav class="nav-shell" data-mobile-nav data-open="false">
		<a class="brand" href="/">
			<svg
				class="nav-logo"
				width="18"
				height="18"
				viewBox="0 0 64 64"
				aria-hidden="true"
				focusable="false"
				xmlns="http://www.w3.org/2000/svg"
			>
				<circle cx="32" cy="32" r="30" fill="#07111b"></circle>
				<circle cx="32" cy="32" r="22" fill="none" stroke="#7cd8f2" stroke-width="3.2"></circle>
				<path
					d="M18 38 L28 28 L36 34 L46 22"
					fill="none"
					stroke="#7cd8f2"
					stroke-width="4"
					stroke-linecap="round"
					stroke-linejoin="round"
				></path>
			</svg>
			<span>{SITE_TITLE}</span>
		</a>

		<button
			class="nav-toggle"
			type="button"
			aria-expanded="false"
			aria-label="Toggle navigation"
			data-nav-toggle
		>
			<span></span>
			<span></span>
			<span></span>
		</button>

		<div class="nav-links">
			<a href={currentRealityHref}>Current Reality</a>
			<a href={practiceHref}>Practice</a>
			<div class="nav-subnav" data-subnav>
				<div class="nav-subnav-trigger">
					<a class="nav-primary-link" href={aiPlatformHref}>How We Deploy AI</a>
					<button
						class="nav-subnav-toggle"
						type="button"
						aria-expanded="false"
						aria-label="Open How We Deploy AI links"
						data-subnav-toggle
					>
						<span class="nav-subnav-chevron" aria-hidden="true">▾</span>
					</button>
				</div>
				<div class="nav-subnav-menu" hidden>
					<a class="nav-sublink" href={blueprintHref}>Blueprint</a>
				</div>
			</div>
			<a href={whyHref}>Why NorthLine</a>
			<a href={getStartedHref}>Get Started</a>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 0.85rem 1.25rem 0;
	}

	.nav-shell {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0.72rem 0.95rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
		border: 1px solid var(--surface-line);
		border-radius: 999px;
		background: rgba(7, 13, 22, 0.76);
		backdrop-filter: blur(16px);
		position: relative;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		color: var(--text-strong);
		font-size: 0.84rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.nav-logo {
		width: 24px;
		height: 24px;
		display: block;
		flex: 0 0 auto;
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
	}

	.nav-links a {
		color: var(--text-muted);
		font-size: 0.88rem;
		text-decoration: none;
		transition: color 160ms ease;
	}

	.nav-links a:hover {
		color: var(--text-strong);
	}

	.nav-subnav {
		position: relative;
		display: inline-flex;
		align-items: center;
	}

	.nav-subnav-trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
	}

	.nav-primary-link {
		display: inline-flex;
		align-items: center;
	}

	.nav-subnav-toggle {
		width: 1rem;
		height: 1rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--accent);
		cursor: pointer;
		font: inherit;
		line-height: 1;
		appearance: none;
		-webkit-appearance: none;
		box-shadow: none;
	}

	.nav-subnav-chevron {
		display: inline-block;
		font-size: 0.68rem;
		line-height: 1;
		transform: translateY(-0.04rem);
	}

	.nav-subnav[data-open='true'] .nav-subnav-chevron {
		transform: rotate(180deg) translateY(0.04rem);
	}

	.nav-subnav-menu {
		position: absolute;
		top: calc(100% + 0.7rem);
		left: 0;
		min-width: 9rem;
		padding: 0.55rem;
		border: 1px solid var(--surface-line);
		border-radius: 0.9rem;
		background: rgba(7, 13, 22, 0.96);
		backdrop-filter: blur(16px);
		box-shadow: var(--shadow);
	}

	.nav-subnav-menu[hidden] {
		display: none !important;
	}

	.nav-subnav .nav-sublink {
		display: block;
		padding: 0.35rem 0.45rem;
		border-radius: 0.55rem;
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.nav-subnav .nav-sublink:hover {
		background: rgba(255, 255, 255, 0.04);
	}

	.nav-toggle {
		display: none;
		width: 2.75rem;
		height: 2.75rem;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		gap: 0.22rem;
		padding: 0;
		border: 1px solid var(--surface-line);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.03);
		color: var(--text-strong);
		cursor: pointer;
	}

	.nav-toggle span {
		display: block;
		width: 1rem;
		height: 1px;
		background: currentColor;
	}

	@media (max-width: 720px) {
		.site-header {
			padding: 0.7rem 1rem 0;
		}

		.nav-shell {
			flex-wrap: wrap;
			align-items: center;
			border-radius: 1.5rem;
		}

		.nav-toggle {
			display: inline-flex;
			margin-left: auto;
		}

		.nav-links {
			display: none !important;
			order: 3;
			flex-basis: 100%;
			width: 100%;
			padding-top: 0.35rem;
			flex-direction: column;
			align-items: flex-start;
			gap: 0.85rem;
		}

		.nav-subnav {
			width: 100%;
			display: grid;
			gap: 0.2rem;
		}

		.nav-subnav-trigger {
			width: 100%;
			justify-content: flex-start;
			gap: 0.35rem;
		}

		.nav-subnav-toggle {
			width: 1.5rem;
			height: 1.5rem;
		}

		.nav-subnav-chevron {
			font-size: 0.82rem;
			transform: none;
		}

		.nav-subnav[data-open='true'] .nav-subnav-chevron {
			transform: rotate(180deg);
		}

		.nav-subnav-menu {
			position: static;
			width: 100%;
			min-width: 0;
			margin-top: 0.1rem;
			padding: 0;
			border: 0;
			border-radius: 0;
			background: transparent;
			backdrop-filter: none;
			box-shadow: none;
		}

		.nav-subnav .nav-sublink {
			display: block;
			padding: 0.25rem 0 0.25rem 1rem;
			font-size: 0.76rem;
		}

		.nav-subnav .nav-sublink:hover {
			background: transparent;
		}

		.nav-shell[data-open='true'] .nav-links {
			display: flex !important;
		}
	}
</style>

	<script is:inline src="/scripts/header-nav.js"></script>
